@model List<SV22T1020013.Shop.Models.OrderViewInfo>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active">Lịch sử đơn hàng</li>
            </ol>
        </nav>
        <h1>Lịch sử mua hàng</h1>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4">
        <div class="col-lg-3">
            <div class="filter-card">
                <div class="filter-title"><i class="fas fa-user-circle me-2"></i>Tài khoản</div>
                <div class="d-flex flex-column gap-1">
                    <a href="/Account/Profile" class="filter-label text-decoration-none text-dark">
                        <i class="fas fa-user me-2 text-muted"></i>Thông tin cá nhân
                    </a>
                    <a href="/Account/ChangePassword" class="filter-label text-decoration-none text-dark">
                        <i class="fas fa-key me-2 text-muted"></i>Đổi mật khẩu
                    </a>
                    <a href="/Order/History" class="filter-label active-filter text-decoration-none">
                        <i class="fas fa-box me-2"></i>Lịch sử đơn hàng
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-700">Tất cả đơn hàng <span class="badge bg-secondary ms-1">@Model.Count</span></h5>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-box-open fa-4x d-block mb-3 text-muted"></i>
                    <h5>Chưa có đơn hàng nào</h5>
                    <p class="text-muted small">Hãy mua sắm ngay để trải nghiệm dịch vụ của chúng tôi!</p>
                    <a href="/Product" class="btn btn-danger mt-2 px-4">
                        <i class="fas fa-shopping-bag me-2"></i>Mua sắm ngay
                    </a>
                </div>
            }
            else
            {
                @foreach (var order in Model)
                {
                    var statusClass = order.Status switch {
                        SV22T1020013.Shop.Models.OrderStatusEnum.New       => "status-pending",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Accepted  => "status-confirmed",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Shipping  => "status-shipping",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Completed => "status-delivered",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Cancelled => "status-cancelled",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Rejected  => "status-cancelled",
                        _ => "status-pending"
                    };
                    var statusText = order.Status switch {
                        SV22T1020013.Shop.Models.OrderStatusEnum.New       => "Chờ xác nhận",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Accepted  => "Đã xác nhận",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Shipping  => "Đang giao hàng",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Completed => "Đã giao hàng",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Cancelled => "Đã hủy",
                        SV22T1020013.Shop.Models.OrderStatusEnum.Rejected  => "Đã từ chối",
                        _ => order.Status.ToString()
                    };
                    <div class="order-card">
                        <div class="order-header">
                            <div>
                                <span class="order-id"><i class="fas fa-hashtag me-1 text-muted"></i>Đơn hàng #@order.OrderID</span>
                                <span class="text-muted small ms-3"><i class="fas fa-clock me-1"></i>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <span class="status-badge @statusClass">@statusText</span>
                        </div>
                        <div class="order-body">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    @if (!string.IsNullOrEmpty(order.DeliveryAddress))
                                    {
                                        <div class="text-muted small mb-1">
                                            <i class="fas fa-map-marker-alt me-1"></i>@order.DeliveryAddress
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(order.CustomerPhone))
                                    {
                                        <div class="text-muted small">
                                            <i class="fas fa-phone me-1"></i>@order.CustomerPhone
                                        </div>
                                    }
                                </div>
                                <div class="col-md-3 text-md-center my-2 my-md-0">
                                    <div class="text-muted small">Sản phẩm</div>
                                    <div class="fw-600">@order.Details.Count mặt hàng</div>
                                </div>
                                <div class="col-md-3 text-md-end d-flex gap-2 justify-content-start justify-content-md-end">
                                    <a href="/Order/Detail/@order.OrderID" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye me-1"></i>Chi tiết
                                    </a>
                                    <a href="/Order/Track/@order.OrderID" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-truck me-1"></i>Theo dõi
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
