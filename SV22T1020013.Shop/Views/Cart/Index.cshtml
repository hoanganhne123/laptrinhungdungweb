@model List<SV22T1020013.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model.Sum(x => x.Subtotal);
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active">Giỏ hàng</li>
            </ol>
        </nav>
        <h1>Giỏ hàng của bạn</h1>
    </div>
</div>

<div class="container mb-5">
    @if (!Model.Any())
    {
        <div class="empty-state py-5">
            <i class="fas fa-shopping-cart fa-4x d-block mb-3 text-muted"></i>
            <h4 class="text-muted">Giỏ hàng trống</h4>
            <p class="text-muted small">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
            <a href="/Product" class="btn btn-danger mt-3 px-4">
                <i class="fas fa-shopping-bag me-2"></i>Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted small">Có <strong>@Model.Count</strong> sản phẩm trong giỏ hàng</span>
                    <form asp-controller="Cart" asp-action="Clear" method="post">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                            <i class="fas fa-trash me-1"></i>Xóa tất cả
                        </button>
                    </form>
                </div>

                <div class="cart-table">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th style="width:50%">Sản phẩm</th>
                                <th class="text-center">Đơn giá</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-center">Thành tiền</th>
                                <th class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(item.Photo))
                                            {
                                                <img class="cart-product-img" src="/images/products/@item.Photo" alt="@item.ProductName" />
                                            }
                                            else
                                            {
                                                <div class="cart-product-img d-flex align-items-center justify-content-center bg-light">
                                                    <i class="fas fa-box text-muted"></i>
                                                </div>
                                            }
                                            <div>
                                                <a href="/Product/Detail/@item.ProductID"
                                                   class="fw-600 text-dark text-decoration-none"
                                                   style="font-size:.88rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                                    @item.ProductName
                                                </a>
                                                @if (!string.IsNullOrEmpty(item.Unit))
                                                {
                                                    <div class="text-muted small">@item.Unit</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="item-price fw-600 text-danger"
                                              data-product-id="@item.ProductID"
                                              data-price="@item.Price"
                                              style="font-size:.9rem;">
                                            @item.Price.ToString("N0") ₫
                                        </span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="qty-control justify-content-center">
                                            <button class="qty-btn" data-product-id="@item.ProductID" data-action="minus">
                                                <i class="fas fa-minus"></i>
                                            </button>
                                            <input type="number" class="qty-input"
                                                   data-product-id="@item.ProductID"
                                                   value="@item.Quantity" min="1" />
                                            <button class="qty-btn" data-product-id="@item.ProductID" data-action="plus">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="item-subtotal fw-700 text-danger"
                                              data-product-id="@item.ProductID"
                                              style="font-size:.9rem;">
                                            @item.Subtotal.ToString("N0") ₫
                                        </span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <button class="btn-remove-item btn btn-sm btn-outline-danger"
                                                data-product-id="@item.ProductID"
                                                title="Xóa">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a href="/Product" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="cart-summary">
                    <h5 class="fw-700 mb-4" style="font-family:'Nunito',sans-serif;color:#1d3557;border-bottom:2px solid #f0f0f0;padding-bottom:12px;">
                        <i class="fas fa-receipt me-2"></i>Tóm tắt đơn hàng
                    </h5>
                    <div class="cart-total-row">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-600" id="cartTotal">@total.ToString("N0") ₫</span>
                    </div>
                    <div class="cart-total-row">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="text-success fw-600">Miễn phí</span>
                    </div>
                    <div class="cart-total-row mt-2 pt-2" style="border-top:2px solid #f0f0f0;">
                        <span class="fw-700">Tổng cộng</span>
                        <span class="cart-total-final" id="cartGrandTotal">@total.ToString("N0") ₫</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Order/Checkout" class="btn btn-danger w-100 mt-4 py-3 fw-700" style="border-radius:12px;font-size:1rem;">
                            <i class="fas fa-lock me-2"></i>Đặt hàng ngay
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Login?returnUrl=/Order/Checkout" class="btn btn-danger w-100 mt-4 py-3 fw-700" style="border-radius:12px;font-size:1rem;">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập để đặt hàng
                        </a>
                        <p class="text-center text-muted small mt-2">
                            Chưa có tài khoản? <a href="/Account/Register" class="text-danger fw-600">Đăng ký ngay</a>
                        </p>
                    }

                    <div class="text-center mt-4">
                        <small class="text-muted d-block mb-2">Thanh toán an toàn</small>
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <span class="badge bg-light text-dark border"><i class="fas fa-shield-alt me-1 text-success"></i>SSL</span>
                            <span class="badge bg-light text-dark border"><i class="fas fa-lock me-1 text-primary"></i>Bảo mật</span>
                            <span class="badge bg-light text-dark border"><i class="fas fa-undo me-1 text-warning"></i>Hoàn tiền</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
