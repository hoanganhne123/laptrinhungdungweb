@model SV22T1020013.Shop.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
    var related = ViewBag.RelatedProducts as IEnumerable<SV22T1020013.Shop.Models.Product> ?? new List<SV22T1020013.Shop.Models.Product>();
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/Product">Sản phẩm</a></li>
                <li class="breadcrumb-item"><a href="/Product?categoryID=@Model.CategoryID">@Model.CategoryName</a></li>
                <li class="breadcrumb-item active" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Model.ProductName</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4">
        <div class="col-md-5">
            <div class="product-detail-img">
                @if (!string.IsNullOrEmpty(Model.Photo))
                {
                    <img id="mainImg" src="/images/products/@Model.Photo" alt="@Model.ProductName"
                         style="max-height:400px;width:100%;object-fit:contain;" />
                }
                else
                {
                    <div style="height:300px;background:#f8f9fa;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-image fa-5x text-muted"></i>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-7">
            <span class="badge" style="background:#fff0f0;color:#e63946;font-weight:600;font-size:.78rem;margin-bottom:10px;">@Model.CategoryName</span>
            <h1 class="product-detail-name">@Model.ProductName</h1>

            <div class="d-flex align-items-center gap-3 my-3">
                <div class="product-detail-price">@Model.Price.ToString("N0") ₫</div>
                @if (!string.IsNullOrEmpty(Model.Unit))
                {
                    <span class="badge bg-light text-dark border">/ @Model.Unit</span>
                }
                @if (Model.IsSelling)
                {
                    <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Đang bán</span>
                }
                else
                {
                    <span class="badge bg-secondary">Ngừng bán</span>
                }
            </div>

            <hr />
            @if (!string.IsNullOrEmpty(Model.ProductDescription))
            {
                <p class="text-muted" style="font-size:.9rem;line-height:1.7;">@Model.ProductDescription</p>
                <hr />
            }

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <div style="background:#f8f9fa;border-radius:10px;padding:10px 14px;font-size:.8rem;">
                        <i class="fas fa-shipping-fast text-primary me-2"></i><strong>Giao hàng nhanh 24h</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div style="background:#f8f9fa;border-radius:10px;padding:10px 14px;font-size:.8rem;">
                        <i class="fas fa-shield-alt text-success me-2"></i><strong>Bảo hành chính hãng</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div style="background:#f8f9fa;border-radius:10px;padding:10px 14px;font-size:.8rem;">
                        <i class="fas fa-undo text-warning me-2"></i><strong>Đổi trả 15 ngày</strong>
                    </div>
                </div>
                <div class="col-6">
                    <div style="background:#f8f9fa;border-radius:10px;padding:10px 14px;font-size:.8rem;">
                        <i class="fas fa-certificate text-danger me-2"></i><strong>Hàng chính hãng 100%</strong>
                    </div>
                </div>
            </div>

            @if (Model.IsSelling)
            {
                <div class="d-flex align-items-center gap-3 mt-4 flex-wrap">
                    <div class="qty-control">
                        <button class="qty-btn" id="qtyMinus" type="button"><i class="fas fa-minus"></i></button>
                        <input type="number" id="qtyInput" class="qty-input" value="1" min="1" max="999" />
                        <button class="qty-btn" id="qtyPlus" type="button"><i class="fas fa-plus"></i></button>
                    </div>
                    <button class="btn-primary-custom btn-add-cart-detail" data-product-id="@Model.ProductID" style="flex:1;min-width:180px;">
                        <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                    </button>
                    <a href="/Cart" class="btn-outline-custom">
                        <i class="fas fa-shopping-cart me-2"></i>Xem giỏ hàng
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-warning mt-3"><i class="fas fa-exclamation-triangle me-2"></i>Sản phẩm hiện đã ngừng bán.</div>
            }
        </div>
    </div>

    @if (related.Any())
    {
        <hr class="my-5" />
        <h3 class="section-title">Sản phẩm liên quan</h3>
        <div class="row row-cols-2 row-cols-sm-2 row-cols-md-4 g-3">
            @foreach (var p in related)
            {
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrap">
                            <a href="/Product/Detail/@p.ProductID">
                                @if (!string.IsNullOrEmpty(p.Photo))
                                {
                                    <img src="/images/products/@p.Photo" alt="@p.ProductName" loading="lazy" />
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/300x300/f8f9fa/aaa?text=No+Image" alt="@p.ProductName" loading="lazy" />
                                }
                            </a>
                        </div>
                        <div class="product-body">
                            <a href="/Product/Detail/@p.ProductID" class="product-name">@p.ProductName</a>
                            <div class="product-price">@p.Price.ToString("N0") ₫</div>
                            <button class="btn-add-cart" data-product-id="@p.ProductID">
                                <i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
document.querySelector('.btn-add-cart-detail')?.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    const productID = this.dataset.productId;
    const qty = parseInt(document.getElementById('qtyInput').value) || 1;
    fetch('/Cart/AddToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `productID=${productID}&quantity=${qty}`
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            showToast(data.message);
            const badge = document.getElementById('cartBadge');
            if (badge) { badge.textContent = data.cartCount; badge.style.display = 'flex'; }
            const btn = document.querySelector('.btn-add-cart-detail');
            btn.innerHTML = '<i class="fas fa-check me-2"></i>Đã thêm vào giỏ!';
            btn.style.background = '#198754';
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng';
                btn.style.background = '';
            }, 2000);
        }
    });
});
</script>
}
