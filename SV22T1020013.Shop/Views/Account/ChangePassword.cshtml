@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/Account/Profile">Tài khoản</a></li>
                <li class="breadcrumb-item active">Đổi mật khẩu</li>
            </ol>
        </nav>
        <h1>Đổi mật khẩu</h1>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4">

        <div class="col-lg-3">
            <div class="filter-card">
                <div class="filter-title"><i class="fas fa-user-circle me-2"></i>Tài khoản</div>
                <div class="d-flex flex-column gap-1">
                    <a href="/Account/Profile" class="filter-label text-decoration-none text-dark">
                        <i class="fas fa-user me-2 text-muted"></i>Thông tin cá nhân
                    </a>
                    <a href="/Account/ChangePassword" class="filter-label active-filter text-decoration-none">
                        <i class="fas fa-key me-2"></i>Đổi mật khẩu
                    </a>
                    <a href="/Order/History" class="filter-label text-decoration-none text-dark">
                        <i class="fas fa-box me-2 text-muted"></i>Lịch sử đơn hàng
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="checkout-section">
                <h5><i class="fas fa-key me-2 text-danger"></i>Đổi mật khẩu</h5>

                @if (TempData["SuccessMsg"] != null)
                {
                    <div class="alert alert-success py-2 mb-3">
                        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMsg"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                {
                    <div class="alert alert-danger py-2 mb-3">
                        <i class="fas fa-exclamation-circle me-2"></i>@ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage
                    </div>
                }

                <form action="/Account/ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-600">
                            Mật khẩu hiện tại <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <input type="password" name="oldPassword" id="oldPassword"
                                   class="form-control" placeholder="Nhập mật khẩu hiện tại" required />
                            <button type="button" class="input-group-text bg-light"
                                    onclick="togglePwd('oldPassword','eye1')">
                                <i class="fas fa-eye text-muted" id="eye1"></i>
                            </button>
                        </div>
                        @if (ViewData.ModelState.ContainsKey("oldPassword"))
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["oldPassword"]?.Errors.FirstOrDefault()?.ErrorMessage</div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-600">
                            Mật khẩu mới <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <input type="password" name="newPassword" id="newPassword"
                                   class="form-control" placeholder="Ít nhất 6 ký tự" required />
                            <button type="button" class="input-group-text bg-light"
                                    onclick="togglePwd('newPassword','eye2')">
                                <i class="fas fa-eye text-muted" id="eye2"></i>
                            </button>
                        </div>
                        @if (ViewData.ModelState.ContainsKey("newPassword"))
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["newPassword"]?.Errors.FirstOrDefault()?.ErrorMessage</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-600">
                            Xác nhận mật khẩu mới <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <input type="password" name="confirmPassword" id="confirmPassword"
                                   class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                            <button type="button" class="input-group-text bg-light"
                                    onclick="togglePwd('confirmPassword','eye3')">
                                <i class="fas fa-eye text-muted" id="eye3"></i>
                            </button>
                        </div>
                        @if (ViewData.ModelState.ContainsKey("confirmPassword"))
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["confirmPassword"]?.Errors.FirstOrDefault()?.ErrorMessage</div>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-save me-2"></i>Lưu mật khẩu mới
                        </button>
                        <a href="/Account/Profile" class="btn btn-outline-secondary px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function togglePwd(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fas fa-eye-slash text-muted';
            } else {
                input.type = 'password';
                icon.className = 'fas fa-eye text-muted';
            }
        }
    </script>
}
