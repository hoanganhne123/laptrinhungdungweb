@{
    ViewBag.Title = "Đăng nhập";
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>LiteCommerce - Đăng nhập</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <link rel="stylesheet" href="~/lib/overlay-scrollbars/overlayscrollbars.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body class="login-page bg-body-secondary">
    <div class="login-box">
        <div class="login-logo">
            <a><b>HA</b> Shop</a>
        </div>
        <div class="card shadow">
            <div class="card-body login-card-body">
                <p class="login-box-msg">Đăng nhập để bắt đầu phiên làm việc</p>

                @* HIỂN THỊ THÔNG BÁO THÀNH CÔNG TỪ ĐĂNG KÝ GỬI VỀ *@
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form action="~/Account/Login" method="post">
                    @Html.AntiForgeryToken()

                    <div class="input-group mb-3">
                        <input type="email" class="form-control" placeholder="Email" autofocus
                               name="username" value="@ViewBag.UserName" required />
                        <div class="input-group-text"><span class="bi bi-envelope"></span></div>
                    </div>
                    <div class="input-group mb-3">
                        <input type="password" class="form-control" placeholder="Mật khẩu" name="password" required />
                        <div class="input-group-text"><span class="bi bi-lock-fill"></span></div>
                    </div>

                    @* HIỂN THỊ LỖI ĐĂNG NHẬP *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="mb-3 text-center">
                            @Html.ValidationMessage("Error", null, new { @class = "text-danger" })
                        </div>
                    }

                    <div class="row">
                        <div class="col-12">
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                <hr />

                @* NÚT ĐĂNG KÝ *@
                <div class="row mt-3">
                    <div class="col-12 text-center">
                        <p class="mb-1 text-muted">Chưa có tài khoản?</p>
                        <a href="~/Account/Register" class="btn btn-outline-success btn-sm w-100">
                            <i class="bi bi-person-plus-fill"></i> Đăng ký tài khoản mới
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <script src="~/lib/overlay-scrollbars/overlayscrollbars.browser.es6.min.js"></script>
    <script src="~/lib/popperjs/popper.min.js"></script>
    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/lib/adminlte/js/adminlte.js"></script>

</body>
</html>