@model Category
@{
    ViewBag.Title = "Xóa loại hàng";
    bool canDelete = ViewBag.CanDelete ?? false;
}

@section PageToolBar {
    @if (canDelete)
    {
        @* Chỉ hiện nút Xóa nếu không có ràng buộc dữ liệu *@
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i> Xóa loại hàng
        </button>
    }
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card @(canDelete ? "card-danger" : "card-warning") card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 @(canDelete ? "text-danger" : "text-warning") fw-bold">
                    <i class="bi @(canDelete ? "bi-exclamation-triangle" : "bi-info-circle") me-2"></i>
                    @(canDelete ? "Xác nhận xóa loại hàng" : "Thông báo hệ thống")
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.CategoryID" method="post">

                    @if (canDelete)
                    {
                        <div class="alert alert-warning d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-circle-fill me-2 fs-5"></i>
                            <div>
                                Bạn có chắc chắn muốn xóa loại hàng <strong>@Model.CategoryName</strong> không? Hành động này không thể hoàn tác.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="bi bi-slash-circle-fill me-2 fs-5"></i>
                            <div>
                                <strong>Không thể xóa:</strong> Loại hàng này đang được sử dụng cho các mặt hàng trong hệ thống. Bạn cần xóa hoặc chuyển đổi loại hàng của các mặt hàng đó trước.
                            </div>
                        </div>
                    }

                    <dl class="row mb-0 ps-2">
                        <dt class="col-sm-3">Tên loại hàng:</dt>
                        <dd class="col-sm-9 fw-bold text-primary">@Model.CategoryName</dd>

                        <dt class="col-sm-3">Mô tả:</dt>
                        <dd class="col-sm-9 text-muted">@(string.IsNullOrEmpty(Model.Description) ? "(Không có mô tả)" : Model.Description)</dd>
                    </dl>

                    @* Hiển thị lỗi hệ thống nếu có *@
                    <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small"></div>
                </form>
            </div>
        </div>
    </div>
</div>