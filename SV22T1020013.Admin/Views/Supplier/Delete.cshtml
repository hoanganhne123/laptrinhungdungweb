@model Supplier
@{
    ViewBag.Title = "Xóa nhà cung cấp";
    bool canDelete = ViewBag.CanDelete ?? false;
}

@section PageToolBar {
    @if (canDelete)
    {
        @* Nút Xóa chỉ xuất hiện khi không có ràng buộc dữ liệu *@
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i> Xóa nhà cung cấp
        </button>
    }
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @* Đổi màu viền Card: đỏ nếu xóa được, vàng nếu bị chặn *@
        <div class="card @(canDelete ? "card-danger" : "card-warning") card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 @(canDelete ? "text-danger" : "text-warning") fw-bold">
                    <i class="bi @(canDelete ? "bi-exclamation-triangle" : "bi-info-circle") me-2"></i>
                    @(canDelete ? "Xác nhận xóa nhà cung cấp" : "Thông báo hệ thống")
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.SupplierID" method="post">

                    @if (canDelete)
                    {
                        <div class="alert alert-warning d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-circle-fill me-2 fs-5"></i>
                            <div>
                                Bạn có chắc chắn muốn xóa nhà cung cấp <strong>@Model.SupplierName</strong> không? Hành động này không thể hoàn tác.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="bi bi-slash-circle-fill me-2 fs-5"></i>
                            <div>
                                <strong>Không thể xóa:</strong> Nhà cung cấp này hiện đang cung cấp các mặt hàng trong hệ thống. Bạn không thể xóa dữ liệu đang được sử dụng.
                            </div>
                        </div>
                    }

                    <dl class="row mb-0 ps-2">
                        <dt class="col-sm-4">Tên nhà cung cấp</dt>
                        <dd class="col-sm-8 fw-bold text-primary">@Model.SupplierName</dd>

                        <dt class="col-sm-4">Tên giao dịch</dt>
                        <dd class="col-sm-8">@Model.ContactName</dd>

                        <dt class="col-sm-4">Điện thoại</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Địa chỉ</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4">Tỉnh / Thành</dt>
                        <dd class="col-sm-8">@Model.Province</dd>
                    </dl>

                    @* Hiển thị lỗi Model nếu có *@
                    <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small"></div>
                </form>
            </div>
        </div>
    </div>
</div>