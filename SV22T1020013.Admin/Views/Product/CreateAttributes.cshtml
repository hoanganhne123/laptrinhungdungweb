@model SV22T1020013.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = ViewBag.Title ?? "Thêm thuộc tính mặt hàng";
}

@section PageToolBar {
    <button type="submit" form="formAttribute" class="btn btn-success">
        <i class="bi bi-save me-1"></i> Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-10">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-list-check me-2 text-success"></i>
                    @ViewBag.Title
                    @if (!string.IsNullOrEmpty(ViewBag.ProductName?.ToString()))
                    {
                        <small class="text-muted fs-6 ms-2">— @ViewBag.ProductName</small>
                    }
                </h5>
            </div>

            <div class="card-body">
                <form id="formAttribute" action="~/Product/SaveAttribute" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="AttributeID" />
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">
                            Tên thuộc tính <span class="text-danger">*</span>
                        </label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="AttributeName" class="form-control"
                                   placeholder="VD: Màu sắc, Kích thước, Chất liệu..." autofocus />
                            <span asp-validation-for="AttributeName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">
                            Giá trị <span class="text-danger">*</span>
                        </label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="AttributeValue" class="form-control"
                                   placeholder="VD: Đỏ, XL, Cotton..." />
                            <span asp-validation-for="AttributeValue" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Thứ tự hiển thị</label>
                        <div class="col-sm-4">
                            <input type="number" asp-for="DisplayOrder" class="form-control" min="1" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-9 offset-sm-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
