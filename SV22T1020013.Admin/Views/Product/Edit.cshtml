@model SV22T1020013.Models.Catalog.Product
@using SV22T1020013.BusinessLayers
@{
    // Thiết lập tiêu đề trang
    ViewBag.Title = Model.ProductID == 0 ? "Thêm mới mặt hàng" : "Cập nhật mặt hàng";

    // Quan trọng: Gán ProductID vào ViewBag để các Partial View (ListPhotos, ListAttributes) sử dụng cho nút "Thêm"
    ViewBag.ProductID = Model.ProductID;
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i> Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                @* Form này chỉ chịu trách nhiệm lưu thông tin cơ bản của Product *@
                <form id="formEdit" action="~/Product/SaveData" method="post" enctype="multipart/form-data">
                    @* Hidden fields *@
                    <input type="hidden" asp-for="ProductID" />
                    @* Trường Photo này sẽ nhận chuỗi Base64 hoặc tên file từ server *@
                    <input type="hidden" asp-for="Photo" id="PhotoData" />

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Tên mặt hàng</label>
                        <div class="col-sm-10">
                            <input type="text" asp-for="ProductName" class="form-control" placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Loại hàng</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="CategoryID"
                                    asp-items="@(await SV22T1020013.Admin.SelectListHelper.Categories())">
                                <option value="0">-- Chọn loại hàng --</option>
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end fw-bold">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="SupplierID"
                                    asp-items="@(await SV22T1020013.Admin.SelectListHelper.Suppliers())">
                                <option value="0">-- Chọn nhà cung cấp --</option>
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Đơn vị tính</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Unit" class="form-control" placeholder="cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end fw-bold">Giá bán</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Price" class="form-control money-input text-end"
                                   value="@Model.Price.ToString("N0")" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Mô tả</label>
                        <div class="col-sm-10">
                            <textarea asp-for="ProductDescription" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Ảnh sản phẩm</label>
                        <div class="col-sm-10">
                            @* Input file dùng để chọn ảnh *@
                            <input type="file" id="filePicker" class="form-control" accept="image/*" onchange="convertToBase64()" />

                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="@(string.IsNullOrEmpty(Model.Photo) ? Url.Content("~/images/products/nophoto.png") : (Model.Photo.StartsWith("data:") ? Model.Photo : Url.Content($"~/images/products/{Model.Photo}")))"
                                     class="img-thumbnail"
                                     style="max-height: 200px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsSelling" id="IsWorking" />
                                <label class="form-check-label fw-bold" for="IsWorking">Mặt hàng này hiện đang được rao bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* CHỈ HIỂN THỊ DANH SÁCH ẢNH VÀ THUỘC TÍNH KHI ĐÃ CÓ PRODUCT ID (CHẾ ĐỘ EDIT) *@
@if (Model.ProductID > 0)
{
    <div class="container-fluid p-0">
        <div id="photo-container" class="mt-4">
            @{
                var photoList = await CatalogDataService.ListPhotosAsync(Model.ProductID);
            }
            @await Html.PartialAsync("ListPhotos", photoList)
        </div>

        <div id="attribute-container" class="mt-4">
            @{
                var attrList = await CatalogDataService.ListAttributesAsync(Model.ProductID);
            }
            @await Html.PartialAsync("ListAttributes", attrList)
        </div>
    </div>
}

@* Script xử lý chuyển ảnh sang String (Base64) *@
<script>
    function convertToBase64() {
        var file = document.getElementById('filePicker').files[0];
        if (file) {
            var reader = new FileReader();
            reader.onloadend = function() {
                var base64String = reader.result;
                // Gán chuỗi vào hidden input để gửi lên server
                document.getElementById('PhotoData').value = base64String;
                // Cập nhật ảnh hiển thị tạm thời
                document.getElementById('imgPreview').src = base64String;
            }
            reader.readAsDataURL(file);
        }
    }
</script>