@model IEnumerable<SV22T1020013.Models.Catalog.ProductPhoto>
@{
    Layout = null;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0 fw-bold text-info">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        @* Đã sửa: Photo -> CreatePhoto *@
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@ViewBag.ProductID?method=add">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px" class="text-center">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:100px" class="text-center">Thứ tự</th>
                            <th style="width:120px" class="text-center">Trạng thái</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center align-middle">
                                        <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/nophoto.png") : item.Photo)"
                                             class="img-thumbnail shadow-sm"
                                             style="max-height:70px; width:70px; object-fit:cover;"
                                             onerror="this.src='/images/products/nophoto.png'" />
                                    </td>
                                    <td class="align-middle">@item.Description</td>
                                    <td class="text-center align-middle">@item.DisplayOrder</td>
                                    <td class="text-center align-middle">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-eye-slash me-1"></i>Đang ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success"><i class="bi bi-eye me-1"></i>Hiển thị</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap align-middle">
                                        @* Đã sửa: Photo -> CreatePhoto *@
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="~/Product/CreatePhoto/@item.ProductID?method=edit&photoId=@item.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @* Đã sửa: Photo -> CreatePhoto *@
                                        <a class="btn btn-sm btn-outline-danger"
                                           href="~/Product/CreatePhoto/@item.ProductID?method=delete&photoId=@item.PhotoID"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa ảnh này không?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-image-fill d-block fs-2 mb-2"></i>
                                    Chưa có ảnh nào cho mặt hàng này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>