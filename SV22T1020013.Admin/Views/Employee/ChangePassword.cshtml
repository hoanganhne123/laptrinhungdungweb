@model SV22T1020013.Models.HR.Employee
@{
    ViewBag.Title = "Mật khẩu nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Đổi mật khẩu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @* Logic: Hiển thị thông báo lỗi từ phía Server (ModelState) *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @Html.ValidationSummary(true, "")
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @* Logic: Sửa lại key TempData thành PasswordSuccess để không bị lẫn với trang Phân quyền *@
        @if (TempData["PasswordSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["PasswordSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Đổi mật khẩu nhân viên
                </h5>
            </div>

            <div class="card-body">
                @* Logic: Khai báo Action gửi về hàm SavePassword trong Controller *@
                <form id="formChangePassword" action="~/Employee/SavePassword" method="post">
                    @Html.AntiForgeryToken()

                    @* Logic: Truyền ID nhân viên ẩn để Controller biết đang cập nhật cho ai *@
                    <input type="hidden" name="employeeId" value="@Model.EmployeeID" />

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            @* Logic: Đổ dữ liệu thật từ Model *@
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-key me-1"></i>
                            Thông tin mật khẩu
                        </legend>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            @* Logic: Thêm thuộc tính name để bắt dữ liệu và required để check trống cơ bản *@
                            <input type="password"
                                   name="newPassword"
                                   class="form-control"
                                   placeholder="Nhập mật khẩu mới"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu</label>
                            @* Logic: Thêm thuộc tính name khớp với tham số đầu vào của Controller *@
                            <input type="password"
                                   name="confirmPassword"
                                   class="form-control"
                                   placeholder="Nhập lại mật khẩu mới"
                                   required />
                        </div>
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>