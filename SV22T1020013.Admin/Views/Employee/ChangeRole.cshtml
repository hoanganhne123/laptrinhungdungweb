@using SV22T1020013.Admin
@model SV22T1020013.Models.HR.Employee
@{
    ViewBag.Title = "Phân quyền nhân viên";

    // Kiểm tra an toàn Model để tránh lỗi NullReferenceException
    if (Model == null)
    {
        <div class="alert alert-danger shadow-sm">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>
            Không tìm thấy thông tin nhân viên.
        </div>
        return;
    }

    // Tách chuỗi RoleNames từ DB thành danh sách để kiểm tra (Check)
    var currentRoles = Model.RoleNames?.Split(',')
                                     .Select(r => r.Trim())
                                     .ToList() ?? new List<string>();

    // Danh sách các Role thực tế khớp với class WebUserRoles của bạn
    var roles = new List<(string Name, string Description)> {
        (WebUserRoles.Administrator, "Toàn quyền quản trị hệ thống, quản lý nhân viên và cấu hình."),
        (WebUserRoles.DataManager, "Quản lý danh mục dữ liệu (Sản phẩm, Khách hàng, Nhà cung cấp...)."),
        (WebUserRoles.Sales, "Quản lý đơn hàng, lập hóa đơn và xử lý bán hàng.")
    };
}

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@* LOGIC: CHỈ HIỂN THỊ THÔNG BÁO LIÊN QUAN ĐẾN QUYỀN (ROLE) *@
@if (TempData["RoleSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Thành công!</strong> @TempData["RoleSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["RoleError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Lỗi!</strong> @TempData["RoleError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* Logic: Hiển thị lỗi từ ModelState (nếu có) *@
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-x-circle-fill me-2"></i>
        @Html.ValidationSummary(true, "")
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2 text-primary"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" action="~/Employee/SaveRole" method="post">
                    @Html.AntiForgeryToken()
                    @* Truyền ngầm ID nhân viên để xử lý cập nhật *@
                    <input type="hidden" name="employeeId" value="@Model.EmployeeID" />

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-primary fw-bold mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0 border rounded p-3 bg-light">
                            <dt class="col-sm-3">Họ và tên:</dt>
                            <dd class="col-sm-9 fw-bold">@Model.FullName</dd>

                            <dt class="col-sm-3">Email:</dt>
                            <dd class="col-sm-9 text-muted">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái:</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-primary fw-bold mb-3">
                            <i class="bi bi-shield-lock me-1"></i>
                            Danh sách quyền hệ thống
                        </legend>

                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-light text-secondary">
                                    <tr>
                                        <th style="width:80px;" class="text-center">Chọn</th>
                                        <th style="width:200px;">Mã quyền (Role)</th>
                                        <th>Mô tả chức năng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var role in roles)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <div class="form-check d-inline-block">
                                                    <input class="form-check-input" type="checkbox"
                                                           name="roles" value="@role.Name"
                                                           @(currentRoles.Contains(role.Name) ? "checked" : "") />
                                                </div>
                                            </td>
                                            <td><code class="fw-bold">@role.Name</code></td>
                                            <td>@role.Description</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>