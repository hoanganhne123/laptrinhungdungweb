@model SV22T1020013.Models.HR.Employee
@{
    ViewBag.Title = "Xóa nhân viên";
    bool canDelete = ViewBag.CanDelete ?? false;
}

@section PageToolBar {
    @if (canDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xóa nhân viên
        </button>
    }
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card @(canDelete ? "card-danger" : "card-warning") card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 @(canDelete ? "text-danger" : "text-warning") fw-bold">
                    <i class="bi @(canDelete ? "bi-person-x-fill" : "bi-info-circle") me-2"></i>
                    @(canDelete ? "Xác nhận xóa nhân viên" : "Thông báo hệ thống")
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.EmployeeID" method="post">

                    @if (canDelete)
                    {
                        <div class="alert alert-warning d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div>
                                Bạn có chắc chắn muốn xóa nhân viên <strong>@Model.FullName</strong> không? Dữ liệu không thể phục hồi.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="bi bi-slash-circle-fill me-2 fs-5"></i>
                            <div>
                                <strong>Không thể xóa:</strong> Nhân viên này đã tham gia xử lý đơn hàng trong hệ thống nên không được phép xóa.
                            </div>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-2 text-center border-end">
                            <img src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail shadow-sm mb-2"
                                 style="width: 100%; max-width: 150px;"
                                 alt="Ảnh nhân viên" />
                        </div>

                        <div class="col-md-10">
                            <dl class="row mb-0 ps-3">
                                <dt class="col-sm-3">Họ và tên:</dt>
                                <dd class="col-sm-9 fw-bold text-primary">@Model.FullName</dd>

                                <dt class="col-sm-3">Ngày sinh:</dt>
                                <dd class="col-sm-9">@Model.BirthDate?.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-3">Điện thoại:</dt>
                                <dd class="col-sm-9">@Model.Phone</dd>

                                <dt class="col-sm-3">Email:</dt>
                                <dd class="col-sm-9">@Model.Email</dd>

                                <dt class="col-sm-3">Địa chỉ:</dt>
                                <dd class="col-sm-9">@Model.Address</dd>

                                <dt class="col-sm-3">Trạng thái:</dt>
                                <dd class="col-sm-9">
                                    @if (Model.IsWorking)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã nghỉ việc</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small"></div>
                </form>
            </div>
        </div>
    </div>
</div>