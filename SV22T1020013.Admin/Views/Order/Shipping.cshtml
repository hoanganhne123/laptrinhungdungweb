@model Order
@{
    Layout = null;
}

<div class="modal-header text-bg-info">
    <strong class="modal-title">Chuyển đơn hàng sang trạng thái giao hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form action="~/Order/Shipping/@Model.OrderID" method="post" onsubmit="return formSubmit(this)">
    <div class="modal-body">
        <div class="mb-3">
            <label class="form-label">Người giao hàng (Shipper):</label>
            <select class="form-select" name="shipperID" required>
                @foreach (var item in await SV22T1020013.Admin.SelectListHelper.Shippers())
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>

        <div class="alert alert-info d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Xác nhận chuyển đơn hàng #@Model.OrderID cho người giao hàng đã chọn?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bicycle me-1"></i> Xác nhận giao hàng
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>