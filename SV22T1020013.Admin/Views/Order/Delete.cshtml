@model Order
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">Xác nhận xóa đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form action="~/Order/Delete/@Model.OrderID" method="post" onsubmit="return formSubmit(this)">
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-trash me-2"></i>
            Bạn có chắc chắn muốn xóa đơn hàng #@Model.OrderID? (Hành động này không thể hoàn tác)
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xóa ngay
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>