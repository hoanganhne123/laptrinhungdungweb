@model Order
@{
    Layout = null;
}
<div class="modal-header text-bg-warning">
    <strong class="modal-title">Xác nhận hủy đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form action="~/Order/Cancel/@Model.OrderID" method="post" onsubmit="return formSubmit(this)">
    <div class="modal-body">
        <div class="alert alert-warning d-flex align-items-center">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Bạn có thực sự muốn hủy đơn hàng #@Model.OrderID hay không?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>