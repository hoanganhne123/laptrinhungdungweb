@model PagedResult<Product>
@{
    Layout = null;
}
@foreach  (var item in Model.DataItems)
{
    <form method="post" class="border rounded p-2 mb-2" onsubmit="addCartItem(event,this)">
        <strong>@item.ProductName</strong>
        <input type="hidden" name="productId" value="@item.ProductID" />
        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/demo.png"
                     class="img-fluid border" style="max-height:100px" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Giá</label>
                        <input class="form-control form-control-sm money-input"
                               name="price"
                               value="@item.Price" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number"
                               name="quantity"
                               min="1"
                               value="1"
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}
@if (Model.PageCount > 1)
{
    <ul class="pagination pagination-sm justify-content-between mb-0 mt-3">
        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
            <a class="page-link" href="javascript:;"
               onclick="@(Model.Page > 1 ? $"paginationSearch(event, document.getElementById('formSearch'), {Model.Page - 1})" : "return false;")">
                <i class="bi bi-chevron-left"></i> Trước
            </a>
        </li>

        <li class="page-item disabled">
            <span class="page-link text-dark fw-bold">Trang @Model.Page / @Model.PageCount</span>
        </li>

        <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
            <a class="page-link" href="javascript:;"
               onclick="@(Model.Page < Model.PageCount ? $"paginationSearch(event, document.getElementById('formSearch'), {Model.Page + 1})" : "return false;")">
                Sau <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
}