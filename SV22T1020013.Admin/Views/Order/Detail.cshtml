@model Tuple<OrderViewInfo, List<OrderDetailViewInfo>>
@using SV22T1020013.Models.Sales
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var order = Model.Item1;
    var details = Model.Item2;
    decimal totalSum = 0;
}

@section PageToolBar {
    <div class="btn-group">
        <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
        </button>
        <ul class="dropdown-menu">
            @* 1. Duyệt đơn: Chỉ khi đơn hàng mới (New = 1) *@
            @if (order.Status == OrderStatusEnum.New)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Accept/@order.OrderID">Duyệt đơn hàng</a></li>
                <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@order.OrderID">Từ chối đơn hàng</a></li>
            }

            @* 2. Giao hàng: Chỉ khi đã duyệt (Accepted = 2) *@
            @if (order.Status == OrderStatusEnum.Accepted)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@order.OrderID">Chuyển giao hàng</a></li>
            }

            @* 3. Hoàn tất: Chỉ khi đang giao (Shipping = 3) *@
            @if (order.Status == OrderStatusEnum.Shipping)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Finish/@order.OrderID">Hoàn tất đơn hàng</a></li>
            }

            @* 4. HỦY ĐƠN: Không cho hủy nếu đã Hoàn tất (Completed), đã Hủy (Cancelled) hoặc Từ chối (Rejected) *@
            @if (order.Status != OrderStatusEnum.Completed &&
                    order.Status != OrderStatusEnum.Cancelled &&
                    order.Status != OrderStatusEnum.Rejected)
            {
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@order.OrderID">Hủy đơn hàng</a></li>
            }
        </ul>
    </div>

    @* 6. XÓA ĐƠN: Chỉ cho phép xóa nếu đơn mới, đã hủy hoặc bị từ chối *@
    @if (order.Status == OrderStatusEnum.New ||
             order.Status == OrderStatusEnum.Cancelled ||
             order.Status == OrderStatusEnum.Rejected)
    {
        <a href="~/Order/Delete/@order.OrderID" class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i> Xóa đơn hàng
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="alert alert-info mb-3">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Trạng thái đơn hàng:</strong>
    <span class="badge @(order.Status == OrderStatusEnum.Completed ? "bg-success" : (order.Status == OrderStatusEnum.Cancelled || order.Status == OrderStatusEnum.Rejected ? "bg-danger" : "bg-primary"))">
        @switch (order.Status)
        {
            case OrderStatusEnum.New:
                <text>Đơn hàng mới (Chờ duyệt)</text>
                break;
            case OrderStatusEnum.Accepted:

                <text>Đã xác nhận (Chờ giao hàng)</text>
                break;
            case OrderStatusEnum.Shipping:

                <text>Đang giao hàng</text>
                break;
            case OrderStatusEnum.Completed:

                <text>Thành công (Đã kết thúc)</text>
                break;
            case OrderStatusEnum.Cancelled:

                <text>Đã hủy</text>
                break;
            case OrderStatusEnum.Rejected:

                <text>Bị từ chối</text>
                break;
            default:

                <text>Không xác định</text>
                break;
        }
    </span>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card card-outline card-primary mb-3">
            <div class="card-header"><h5 class="card-title">Thông tin đơn hàng</h5></div>
            <div class="card-body">
                <p class="mb-1"><b>Mã đơn:</b> @order.OrderID</p>
                <p class="mb-1"><b>Ngày lập:</b> @order.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-0"><b>Nhân viên lập:</b> @order.EmployeeName</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-outline card-info mb-3">
            <div class="card-header"><h5 class="card-title">Khách hàng</h5></div>
            <div class="card-body">
                <p class="mb-1"><b>Tên:</b> @order.CustomerName (@order.CustomerContactName)</p>
                <p class="mb-1"><b>SĐT:</b> @order.CustomerPhone</p>
                <p class="mb-0"><b>Email:</b> @order.CustomerEmail</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-outline card-success mb-3">
            <div class="card-header"><h5 class="card-title">Giao nhận</h5></div>
            <div class="card-body">
                <p class="mb-1"><b>Người giao:</b> @(string.IsNullOrEmpty(order.ShipperName) ? "Chưa có" : order.ShipperName)</p>
                <p class="mb-1"><b>Địa chỉ nhận:</b> @order.DeliveryAddress</p>
                <p class="mb-0"><b>Tỉnh thành:</b> @order.DeliveryProvince</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-bordered mb-0">
            <thead class="bg-light">
                <tr class="text-center">
                    <th style="width:50px">STT</th>
                    <th>Tên hàng</th>
                    <th style="width:100px">Số lượng</th>
                    <th style="width:150px">Giá bán</th>
                    <th style="width:150px">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (details != null && details.Count > 0)
                {
                    int stt = 1;
                    foreach (var item in details)
                    {
                        var thanhTien = item.Quantity * item.SalePrice;
                        totalSum += thanhTien;
                        <tr>
                            <td class="text-center">@(stt++)</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@thanhTien.ToString("N0")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center">Đơn hàng chưa có chi tiết mặt hàng</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="4" class="text-end">Tổng cộng:</th>
                    <th class="text-end text-danger" style="font-size:1.2rem">@totalSum.ToString("N0") VNĐ</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>