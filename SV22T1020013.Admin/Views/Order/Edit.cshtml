@{
    ViewBag.Title = "Chỉnh sửa đơn hàng";
}

<div class="container-fluid pt-3 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="~/Order" class="btn btn-outline-secondary btn-sm me-2">
                <i class="bi bi-x-lg"></i> Hủy thay đổi
            </a>
            <span class="h5 fw-bold mb-0 text-primary">Cập nhật đơn hàng #ORD-001</span>
        </div>
        <div>
            <button type="button" form="editOrderForm" class="btn btn-success btn-sm px-4 fw-bold shadow-sm">
                <i class="bi bi-check2-circle me-1"></i> LƯU CẬP NHẬT
            </button>
        </div>
    </div>

    <form id="editOrderForm" action="~/Order/Edit" method="post">
        <div class="row g-3">

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white fw-bold py-3">Thông tin khách hàng & Giao nhận</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Khách hàng</label>
                            <select name="CustomerID" class="form-select form-select-sm border-primary">
                                <option value="1" selected>Nguyễn Văn An - 0905.111.222</option>
                                <option value="2">Trần Thị Bình - 0912.333.444</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Trạng thái đơn hàng</label>
                            <select name="OrderStatus" class="form-select form-select-sm bg-light fw-bold text-primary">
                                <option value="1" selected>Đơn hàng mới (Chờ duyệt)</option>
                                <option value="2">Đang giao hàng</option>
                                <option value="3">Đã hoàn thành</option>
                                <option value="4">Đã hủy</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Địa chỉ giao hàng</label>
                            <textarea name="Address" class="form-control form-control-sm" rows="3">123 Nguyễn Huệ, Quận 1, TP. HCM</textarea>
                        </div>

                        <div class="mb-0">
                            <label class="form-label small fw-bold text-muted">Ghi chú nội bộ</label>
                            <input type="text" name="Note" class="form-control form-control-sm" value="Giao giờ hành chính">
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                        <span class="fw-bold">Danh sách mặt hàng</span>
                        <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addProductModal">
                            <i class="bi bi-plus-circle me-1"></i> Thêm món
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="orderItemsTable">
                                <thead class="table-light">
                                    <tr style="font-size: 0.8rem;">
                                        <th class="ps-3">SẢN PHẨM</th>
                                        <th class="text-center" style="width: 150px;">SỐ LƯỢNG</th>
                                        <th class="text-end">ĐƠN GIÁ</th>
                                        <th class="text-end pe-3">THÀNH TIỀN</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold">Sữa tươi Vinamilk 1L</div>
                                            <span class="badge bg-light text-dark border fw-normal">Hộp</span>
                                        </td>
                                        <td>
                                            <div class="input-group input-group-sm">
                                                <button class="btn btn-outline-secondary" type="button">-</button>
                                                <input type="number" class="form-control text-center fw-bold" value="5">
                                                <button class="btn btn-outline-secondary" type="button">+</button>
                                            </div>
                                        </td>
                                        <td class="text-end text-muted">35,000</td>
                                        <td class="text-end fw-bold pe-3">175,000</td>
                                        <td><button class="btn btn-link btn-sm text-danger"><i class="bi bi-trash"></i></button></td>
                                    </tr>
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold">Mì Hảo Hảo Tôm Chua Cay</div>
                                            <span class="badge bg-light text-dark border fw-normal">Thùng</span>
                                        </td>
                                        <td>
                                            <div class="input-group input-group-sm">
                                                <button class="btn btn-outline-secondary" type="button">-</button>
                                                <input type="number" class="form-control text-center fw-bold" value="1">
                                                <button class="btn btn-outline-secondary" type="button">+</button>
                                            </div>
                                        </td>
                                        <td class="text-end text-muted">108,000</td>
                                        <td class="text-end fw-bold pe-3">108,000</td>
                                        <td><button class="btn btn-link btn-sm text-danger"><i class="bi bi-trash"></i></button></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-light py-3 border-0">
                        <div class="row justify-content-end">
                            <div class="col-md-5">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="fw-bold">Tạm tính:</span>
                                    <span>283,000 ₫</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-danger fs-5">TỔNG TIỀN:</span>
                                    <span class="fw-bold text-danger fs-5">283,000 ₫</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 8px;
    }

    .card-header {
        font-size: 0.9rem;
        letter-spacing: 0.3px;
    }

    .input-group .form-control:focus {
        z-index: 0;
    }

    .table td {
        padding: 12px 8px !important;
    }
</style>