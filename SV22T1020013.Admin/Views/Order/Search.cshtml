@using SV22T1020013.Models.Sales
@using SV22T1020013.BusinessLayers
@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.CustomerName</td>
                        <td>@item.CustomerPhone</td>
                        <td>@item.AcceptTime?.ToString("dd/MM/yyyy")</td>
                        <td>@item.EmployeeName</td>
                        <td class="text-end fw-bold">
                            @{
                                // Lưu ý: Cách tính này sẽ gọi DB liên tục trong vòng lặp.
                                // Nếu dữ liệu lớn nên cân nhắc tính từ SQL.
                                var details = await SalesDataService.ListDetailsAsync(item.OrderID);
                                decimal totalOrderAmount = details.Sum(x => x.TotalPrice);
                            }
                            @totalOrderAmount.ToString("N0")
                        </td>
                        <td class="text-center">
                            <span class="badge @GetBadgeClass(item.Status)">
                                @item.Status.GetDescription()
                            </span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* PHẦN PHÂN TRANG (ĐÃ BỎ NÚT KẾ TIẾP/QUAY LẠI) *@
    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active" aria-current="page">
                        <span class="page-link">@p.Page</span>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>

@functions {
    string GetBadgeClass(OrderStatusEnum status) => status switch
    {
        OrderStatusEnum.New => "bg-warning text-dark",
        OrderStatusEnum.Accepted => "bg-info",
        OrderStatusEnum.Shipping => "bg-primary",
        OrderStatusEnum.Completed => "bg-success",
        OrderStatusEnum.Cancelled => "bg-danger",
        OrderStatusEnum.Rejected => "bg-secondary",
        _ => "bg-dark"
    };
}