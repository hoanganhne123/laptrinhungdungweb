@model Order
@{
    Layout = null;
}

<div class="modal-header text-bg-info">
    <strong class="modal-title">Duyệt chấp nhận đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form action="~/Order/Accept/@Model.OrderID" method="post" onsubmit="return formSubmit(this)">
    <div class="modal-body">
        <div class="alert alert-info d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            <div>
                Bạn có chắc chắn muốn duyệt và chấp nhận đơn hàng <strong>#@Model.OrderID</strong> không?
                <br />
                <small>(Sau khi duyệt, đơn hàng sẽ chuyển sang trạng thái chờ giao hàng)</small>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg"></i> Chấp nhận duyệt
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>